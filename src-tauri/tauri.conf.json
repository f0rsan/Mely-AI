{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mely AI",
  "version": "0.1.0",
  "identifier": "com.mely.ai",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "security": {
      "capabilities": ["main-capability"]
    },
    "windows": [
      {
        "label": "main",
        "title": "Mely AI",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "center": true
      }
    ]
  }
}

